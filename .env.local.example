# Copie ce fichier en .env.local et remplis tes vraies valeurs

# Clé secrète Stripe — à récupérer sur dashboard.stripe.com
STRIPE_SECRET_KEY=votre_cle_secrete_stripe

# URL de ton site (sans slash final)
NEXT_PUBLIC_URL=http://localhost:3000

# Montant déjà collecté en euros (mettre à jour manuellement)
NEXT_PUBLIC_AMOUNT_RAISED=0
